# Server
NODE_ENV=development
PORT=8080

# PostgreSQL (local docker or Railway-provided DATABASE_URL)
DATABASE_URL=postgresql://user:password@localhost:5432/dream_sales?connection_limit=20&pool_timeout=10

# JWT
JWT_SECRET=change-me-in-prod
JWT_EXPIRES_IN=7d

# CORS — comma-separated allowed origins (frontend URLs)
ALLOWED_ORIGINS=http://localhost:3000

# Redis — leave empty to use in-memory cache fallback
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=

# Combo unit price (VND) — used by breakaway fee tiers
COMBO_PRICE=1800000
