rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Calculator data ("Tính hoa hồng") — open to ANY signed-in Google user,
    // but each account can only read/write its OWN data, scoped under its uid.
    match /users/{uid}/salesMonths/{monthId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    match /users/{uid}/salesMembers/{memberId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    match /userPrefs/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
